{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Aspire": {
    "Services": {
      "Api": {
        "HttpEndpoint": "https://localhost:7160",
        "Environment": "Development"
      },
      "React": {
        "Port": 3000,
        "Environment": "development"
      }
    },
    "Observability": {
      "OtlpEndpoint": "https://localhost:21007",
      "EnableOpenTelemetry": true,
      "EnableTracing": true,
      "EnableMetrics": true,
      "EnableConsoleExporter": true
    }
  }
}
