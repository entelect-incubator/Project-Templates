{
  "name": "pizza-ordering-app",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:pizza-ordering-app": "node dist/pizza-ordering-app/server/server.mjs",
    "generate:api": "cd ../../clients/generation && generate-angular-client.bat && cd ../../frontend/Angular",
    "download:spec": "powershell -ExecutionPolicy Bypass -File ../../clients/generation/download-spec.ps1",
    "api": "dotnet run --project \"C:/Dev/Incubator/.NET-Template/backend/.NET/3.VerticalSliceArchitecture/2.Minimal/Api/Api.csproj\"",
    "aspire": "dotnet run .\\aspire\\apphost.cs",
    "dev": "concurrently -k -n API,ANGULAR -c cyan,green \"npm:api\" \"npm:start\"",
    "vite:dev": "vite"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
